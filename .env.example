# Copy this file to .env and fill in your key. NEVER commit .env.
# Create the key in Google Cloud console (free, no credit card):
#   1. console.cloud.google.com -> new project
#   2. Enable "YouTube Data API v3"
#   3. Credentials -> Create credentials -> API key
#   4. RESTRICT the key: API restrictions -> YouTube Data API v3 only.
#      If deploying to a server, also add an IP restriction for that host.
YOUTUBE_API_KEY=

# Daily quota accounting (YouTube grants 10,000 units/day, resets midnight Pacific).
# The app stops making fresh API calls at the soft stop and serves cache only.
QUOTA_DAILY_BUDGET=10000
QUOTA_SOFT_STOP=9500

# Cache TTLs (seconds)
TTL_SNAPSHOT_S=21600        # channel snapshots / video details: 6h
TTL_LIST_S=86400            # comments, playlists, sections, activities: 24h
TTL_CAPTIONS_S=86400        # captions metadata (cost 50u — don't refetch): 24h
TTL_STATIC_S=2592000        # videoCategories / i18n maps / id resolutions: 30d
TTL_NEGATIVE_S=3600         # not-found / comments-disabled / subs-private: 1h

# Per-IP rate limits (slowapi syntax)
RATE_FRESH=10/minute
RATE_CACHED=60/minute
RATE_EXPENSIVE=3/minute

# Phase 8: Instagram best-effort tier (requires `pip install instaloader`)
ENABLE_INSTAGRAM=false
